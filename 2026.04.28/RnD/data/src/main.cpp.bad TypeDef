using CText=const char*;

enum {no=false,yes=true};
enum class Wrap{yes,no};

template<typename N> static N _val(N o,N h,N l) {return l>o?l:h<o?h:o;}
template<typename N> static N _up(N o,N s,N h,N l,Wrap w=Wrap::no) {return h-o>=s?o+s:w?l:h;}
template<typename N> static N _down(N o,N s,N h,N l,Wrap w=Wrap::no) {return o-l>=s?o-s:w?h:l;}

/// @brief data storage
/// @tparam T : data type
template<typename T>
struct TypeDef {
  using Type=T;
  // using Def=remove_reference_t<Type>;

  //ranges and validators--

  template<typename Q,T l,T h,Wrap w=Wrap::no>
  struct StaticRange:Q {
    void up(T s) {Q::set(_up(Q::get(),s,l,h,w));}
  };

  template<typename Q>
  struct Range:Q {
    Type m_low{0};
    Type m_high{0};
    Wrap wrap{Wrap::no};
    void up(T s) {Q::set(_up(Q::get(),s,m_low,m_high,wrap));}
  };

  // base data types for storage Static/Ref/Value--
  /// @brief compile time data
  /// @tparam T : data
  template<T data>
  struct Static {
    static constexpr Type get() {return data;}
    static constexpr void set(const Type& o) {data=o;}
  };

  /// @brief compile time reference, target data is runtime changeable
  /// @tparam data : reference to target
  template<T& data>
  struct Ref {
    static constexpr Type& get() {return data;}
    static constexpr void set(const Type& o) {data=o;}
  };

  /// @brief runtime data storage
  struct Value {
    Type data;
    constexpr Type& get() const {return data;}
    constexpr Type& get() {return data;}
    constexpr void set(const Type& o) {data=o;}
  };
};

template<const char*& t> using ConstText=TypeDef<const char*>::Ref<t>;
template<char* t> using Text=TypeDef<char*>::Static<t>;
using Int=TypeDef<int>;
using Bool=TypeDef<bool>;
using Float=TypeDef<double>;

int mes{11};
const char* nome{"Rui Azevedo"};
char notas[]{"notes..."};

Int::Value year{1967};//runtime internal storage data
Int::Ref<mes> month;//compile-time reference to runtime read/write data
Int::Static<11> day;//compile time data, read only
ConstText<nome> name;//constant C string reference
Text<notas> notes;//reference to C data buffer, runtime read and write target
Bool::Value happy{no};
Bool::Static<yes> alive;
bool wtf=yes;
Bool::Ref<wtf> woke;
Float::Value v{1.23};

void run() {
  cout<<name.get()<<" "<<year.get()<<"."<<month.get()<<"."<<day.get()<<endl<<notes.get()<<endl;
  notes.get()[0]='v';
  month.get()=89;
  year.set(4567);
  woke.get()=no;
  cout<<name.get()<<" "<<year.get()<<"."<<month.get()<<"."<<day.get()<<endl<<notes.get()<<" "<<woke.get()<<endl;
  cout<<endl;
}

