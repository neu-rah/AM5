#include <iostream>
using namespace std;

struct Nil{};

template<typename CRTP>
struct PartOf {
  template<typename O>
  struct Part:CRTP,O {
    using Of=CRTP;
    using Base=O;
  };
};

template<typename T,T data>
struct StaticData:PartOf<StaticData<T,data>> {
  static constexpr T get() {return data;}
};

struct DataPrint {
  template<typename O>
  struct Part:PartOf<DataPrint>::Part<O> {
    using Base=typename PartOf<DataPrint>::template Part<O>;
    void print() {cout<<Base::get()<<endl;}
  };
};

DataPrint::template Part<StaticData<int,42>::template Part<Nil>> wtf;

int main() {
  // cout<<wtf.get()<<endl;
  wtf.print();
  return 0;
}