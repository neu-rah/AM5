#include <iostream>
using namespace std;

struct Nil {};

template<typename O=Nil>
struct API:O {
  static constexpr void print() {cout<<".";}
};

template<typename O,typename T>
struct App:O::Part<T> {
  static constexpr void print() {
    O::print();
    T::print();
  }
};

